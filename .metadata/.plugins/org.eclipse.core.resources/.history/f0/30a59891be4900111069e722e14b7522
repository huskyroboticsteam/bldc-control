int32_t PID(int32_t target){
    if(!PIDIsEnabled()){
        return(0);
    }

    int current = Hall_GetSpeed(); //from hall sensor/wtv get some sort of data
    int error = target - current;

    integral = integral + error;

    if(integral > outMax){
    	integral = outMax;
    }	else if(integral < outMin) {
    	integral = outMin;
    }

    int derivative = error - lastError;

    int PWMOut = error*kPosition/10 + integral*kIntegral/10 + derivative*kDerivative/10;

    if(PWMOut > outMax) {
    	PWMOut = outMax;
    }	else if(PWMOut < outMin) {
    	PWMOut = outMin;
    }

    lastError = error; //update error

	return PWMOut;

}

